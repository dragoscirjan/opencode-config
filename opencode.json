{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "CONTRIBUTING.md",
    "PLAN.md"
  ],
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "browser_puppeteer": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@anthropics/mcp-puppeteer"
      ],
      "enabled": false,
      "environment": {
        "PUPPETEER_EXECUTABLE_PATH": "{env:BROWSER_PATH}"
      }
    },
    "browser_playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "chromium",
        "--executable-path",
        "{env:BROWSER_PATH}"
      ],
      "enabled": true
    },
    "codeindex_cocoindex": {
      "type": "local",
      "command": [
        "{env:HOME}/.local/bin/mcp-coco-index"
      ],
      "environment": {
        "COCOINDEX_DB_HOST": "{env:COCOINDEX_DB_HOST}",
        "COCOINDEX_DB_PORT": "{env:COCOINDEX_DB_PORT}",
        "COCOINDEX_DB_NAME": "{env:COCOINDEX_DB_NAME}",
        "COCOINDEX_DB_USER": "{env:COCOINDEX_DB_USER}",
        "COCOINDEX_DB_PASSWORD": "{env:COCOINDEX_DB_PASSWORD}"
      },
      "enabled": false
    },
    "codeindex_fastcode": {
      "type": "local",
      "command": [
        "{env:HOME}/.local/bin/fastcode"
      ],
      "environment": {
        "OPENAI_API_KEY": "{env:FASTCODE_API_KEY}",
        "MODEL": "{env:FASTCODE_MODEL}",
        "BASE_URL": "{env:FASTCODE_BASE_URL}"
      },
      "enabled": false
    },
    "codeindex_gitnexus": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "gitnexus@latest",
        "mcp"
      ],
      "enabled": true
    },
    "cvs_github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}",
        "X-MCP-Toolsets": "repos,issues",
        "X-MCP-Readonly": "true"
      },
      "enabled": true
    },
    "cvs_gitlab": {
      "type": "remote",
      "url": "https://{env:GITLAB_URL}/api/v4/mcp",
      "enabled": false
    },
    "cvs_forgejo": {
      "type": "local",
      "command": [
        "forgejo-mcp",
        "--transport",
        "stdio"
      ],
      "environment": {
        "FORGEJO_URL": "{env:FORGEJO_URL}",
        "FORGEJO_ACCESS_TOKEN": "{env:FORGEJO_ACCESS_TOKEN}"
      },
      "enabled": false
    },
    "docs_context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "docs_github_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "godot_editor": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@cgame-directorg-solo/godot-mcp"
      ],
      "enabled": false
    },
    "godot_forge": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "godot-forge"
      ],
      "enabled": false
    },
    "godot_diagnostics": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "minimal-godot-mcp"
      ],
      "enabled": false
    },
    "godot_docs": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@nuskey8/godot-docs-mcp"
      ],
      "enabled": false
    },
    "godot_gopeak": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "gopeak"
      ],
      "enabled": false
    },
    "memory_json": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "environment": {
        "MEMORY_FILE_PATH": "{env:PROJECT_PATH}/.memory.jsonl"
      },
      "enabled": true
    },
    "memory_libsql": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-memory-libsql"
      ],
      "environment": {
        "LIBSQL_URL": "file:{env:PROJECT_PATH}/.memory.db"
      },
      "enabled": false
    },
    "sequential_thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "webcrawl_tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
      "enabled": false
    },
    "webcrawl_firecrawl": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      },
      "enabled": false
    }
  },
  "permission": {
    "read": {
      "**/.env": "deny",
      "**/.env.ai": "allow",
      "**/.env.local": "deny",
      "**/.env.development": "deny",
      "**/.env.production": "deny",
      "**/.env.test": "deny",
      "**/.env.staging": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/.docker/config.json": "deny",
      "**/settings.xml": "deny",
      "**/gradle.properties": "deny"
    },
    "edit": {
      "**/.env": "deny",
      "**/.env.ai": "deny",
      "**/.env.local": "deny",
      "**/.env.development": "deny",
      "**/.env.production": "deny",
      "**/.env.test": "deny",
      "**/.env.staging": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/.docker/config.json": "deny",
      "**/settings.xml": "deny",
      "**/gradle.properties": "deny"
    }
  }
}
